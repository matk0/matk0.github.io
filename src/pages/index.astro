---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import PainCard from '../components/PainCard.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ServiceSection from '../components/ServiceSection.astro';
import ProcessTimeline from '../components/ProcessTimeline.astro';
import CTABand from '../components/CTABand.astro';
import FAQ from '../components/FAQ.astro';
import { t, getLocalizedPaths } from '../i18n';
import type { Lang } from '../i18n';

const lang = (Astro.locals as any).lang as Lang || 'en';
const strings = t(lang);
const paths = getLocalizedPaths(lang);
const bookingHref = `${paths.contact}?focus=calendar`;
---

<Layout
  title={`Matej Lukášik — ${strings.home.heroTitle}`}
  description={strings.home.heroDescription}
  lang={lang}
  currentPath="/"
>
  <Hero
    title={strings.home.heroTitle}
    description={strings.home.heroDescription}
    typewords={strings.home.heroTypewords}
    size="large"
  >
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="#services" class="btn-outline-white">{strings.home.ctaSecondary}</a>
      <a href={bookingHref} class="btn-white">{strings.home.ctaPrimary}</a>
    </div>
  </Hero>

  <section class="section-padding bg-surface bg-dots relative">
    <div class="container mx-auto">
      <h2 class="text-2xl md:text-4xl font-bold text-heading text-center mb-12 max-w-3xl mx-auto reveal">
        {strings.home.painTitle}
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="reveal reveal-delay-1">
          <PainCard imageSrc="/images/pain-clarity.webp" title={strings.home.pain1Title} description={strings.home.pain1Description} />
        </div>
        <div class="reveal reveal-delay-2">
          <PainCard imageSrc="/images/pain-value.webp" title={strings.home.pain2Title} description={strings.home.pain2Description} />
        </div>
        <div class="reveal reveal-delay-3">
          <PainCard imageSrc="/images/pain-security.webp" title={strings.home.pain3Title} description={strings.home.pain3Description} />
        </div>
      </div>
    </div>
  </section>

  <section id="services" class="section-padding bg-surface-alt relative">
    <div class="container mx-auto">
      <h2 class="text-2xl md:text-4xl font-bold text-center mb-12 reveal">
        <span class="gradient-text-dark">{strings.home.servicesTitle}</span>
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="reveal reveal-delay-1 h-full">
          <ServiceCard imageSrc="/images/service-strategy.webp" title={strings.home.consultingTitle} description={strings.home.consultingDescription} href="#consulting" linkText={strings.home.learnMore} />
        </div>
        <div class="reveal reveal-delay-2 h-full">
          <ServiceCard imageSrc="/images/service-implementation.webp" title={strings.home.implementationTitle} description={strings.home.implementationDescription} href="#implementation" linkText={strings.home.learnMore} />
        </div>
        <div class="reveal reveal-delay-3 h-full">
          <ServiceCard imageSrc="/images/service-training.webp" title={strings.home.trainingTitle} description={strings.home.trainingDescription} href="#training" linkText={strings.home.learnMore} />
        </div>
      </div>
    </div>
  </section>

  <ServiceSection
    id="consulting"
    imageSrc="/images/service-strategy.webp"
    title={strings.services.consulting.title}
    subtitle={strings.services.consulting.subtitle}
    description={strings.services.consulting.description}
    includes={strings.services.consulting.includes}
    ctaText={strings.services.consulting.cta}
    ctaHref={`${paths.contact}?service=consulting&focus=contact-form`}
    bg="white"
  />

  <ServiceSection
    id="implementation"
    imageSrc="/images/service-implementation.webp"
    title={strings.services.implementation.title}
    subtitle={strings.services.implementation.subtitle}
    description={strings.services.implementation.description}
    includes={strings.services.implementation.includes}
    ctaText={strings.services.implementation.cta}
    ctaHref={`${paths.contact}?service=implementation&focus=contact-form`}
    reversed
    bg="alt"
  />

  <ServiceSection
    id="training"
    imageSrc="/images/service-training.webp"
    title={strings.services.training.title}
    subtitle={strings.services.training.subtitle}
    description={strings.services.training.description}
    includes={strings.services.training.includes}
    ctaText={strings.services.training.cta}
    ctaHref={`${paths.contact}?service=training&focus=contact-form`}
    bg="white"
  />

  <ProcessTimeline title={strings.home.processTitle} steps={strings.home.processSteps} />

  <section id="about" class="section-padding bg-surface">
    <div class="container mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <div class="reveal">
          <div class="w-full max-w-[560px] mx-auto">
            <div class="aspect-[4/5] max-h-[680px] rounded-2xl overflow-hidden bg-primary-light border border-border shadow-sm">
              <img src="/images/about-matej.webp" alt="Matej Lukášik" class="w-full h-full object-cover" />
            </div>
            <div class="mt-6 lg:mt-8 text-center">
              <h2 class="text-4xl md:text-5xl font-bold text-heading">{strings.about.bioName}</h2>
              <p class="mt-3 text-lg md:text-xl text-primary font-semibold">{strings.about.bioTitle}</p>
            </div>
          </div>
        </div>
        <div class="reveal reveal-delay-1 max-w-2xl">
          {strings.about.bioText.split('\n\n').map((paragraph) => (
            <p class="text-body text-lg leading-relaxed mb-5 last:mb-0">{paragraph}</p>
          ))}
        </div>
      </div>
    </div>
  </section>

  <FAQ title={strings.contact.faqTitle} items={strings.contact.faq} />

  <CTABand title={strings.home.ctaBandTitle} description={strings.home.ctaBandDescription}>
    <a href={bookingHref} class="btn-white">{strings.home.ctaPrimary}</a>
  </CTABand>
</Layout>
