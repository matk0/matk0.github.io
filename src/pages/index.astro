---
import Layout from '../layouts/Layout.astro';
import { DOMAINS, getLocalizedPaths } from '../i18n';
import type { Lang } from '../i18n';

const lang = ((Astro.locals as any).lang as Lang) || 'en';

type ProfileLinkIcon = 'email' | 'x' | 'linkedin';

const pageCopy = {
  en: {
    profile: {
      greeting: 'Strategic Advisor to Founder-Led Digital Businesses',
      description:
        'Matej Lukášik helps founders resolve consequential decisions across business model, brand, product, and technology.',
      statement: 'For founders building businesses around work they genuinely believe in.',
      introduction:
        'I help you find the real constraint, make the difficult decision, and turn it into one coherent direction.',
      offerLine: null,
      cta: 'See how we can work together',
    },
    tensions: {
      eyebrow: 'Where I work',
      title: 'I help founders turn competing truths into one clear strategic decision.',
      introduction:
        'The difficult problems live between disciplines. I work where two necessary truths pull the business in different directions.',
      pairs: [
        ['Authenticity', 'Commercial viability'],
        ['Self-expression', 'Customer reality'],
        ['Aesthetics', 'Conversion'],
        ['Meaning', 'Money'],
        ['Intuition', 'Evidence'],
        ['Vision', 'Implementation'],
      ],
      explanation:
        'Both sides are usually true. The answer is not always a compromise. It is knowing what must be preserved, what can change, and what the business is actually trying to become.',
      conclusion: 'I help founders turn that tension into one clear strategic decision.',
    },
    work: {
      eyebrow: 'The work',
      title: 'See the whole. Find the constraint. Decide what changes.',
      description:
        'The real constraint may sit in the offer, positioning, customer journey, product, technology—or in a decision only the founder can make.',
      descriptionTwo:
        'I build a model of the whole system, separate causes from symptoms, and translate the conclusion into priorities your team can execute.',
      method: [
        {
          number: '01',
          title: 'Diagnose',
          description:
            'Understand the founder, business model, customer, brand, product, and technology as one system.',
