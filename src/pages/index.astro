---
import Layout from '../layouts/Layout.astro';
import { DOMAINS } from '../i18n';
import type { Lang } from '../i18n';

const lang = ((Astro.locals as any).lang as Lang) || 'en';
const POST_WORK_URL = 'https://post.work/';

type ProfileParagraph =
  | { text: string }
  | { before: string; linkText: string; href: string; after: string };

const profiles = {
  en: {
    greeting: 'Hi,',
    description:
      'Matej Lukášik is building post.work to clear the machinery of e-commerce from the path of authentic creation.',
    paragraphs: [
      { text: 'My name is Matej Lukášik and when it comes to work, I believe we should all focus on one thing: AUTHENTIC CREATION.' },
      {
        before: 'I am building ',
        linkText: 'post.work',
        href: POST_WORK_URL,
        after: ' to clear the machinery of e-commerce from your path, so you can fully focus on your creation while enjoying material abundance.',
      },
    ],
  },
  sk: {
    greeting: 'Ahoj,',
    description:
      'Matej Lukášik buduje post.work, aby tvorcom odstránil z cesty e-commerce prekážky a nechal priestor autentickej tvorbe.',
    paragraphs: [
      { text: 'Volám sa Matej Lukášik a verím, že by sme sa všetci mali sústrediť na jednu vec: AUTENTICKÚ TVORBU.' },
      {
        before: 'Budujem ',
        linkText: 'post.work',
        href: POST_WORK_URL,
        after: ', aby som pre Vás odstránil komplexitu e-commerce, tak aby ste sa mohli sústrediť na Vašu tvorbu a zároveň si užívať materiálnu hojnosť.',
      },
    ],
  },
} satisfies Record<Lang, { greeting: string; description: string; paragraphs: ProfileParagraph[] }>;

const links = [
  { label: 'Email', href: 'mailto:matej@post.work' },
  { label: 'X', href: 'https://x.com/matejlukasik' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/matej-lukasik' },
];

const profile = profiles[lang];
---

<Layout
  title="Matej Lukášik | post.work"
  description={profile.description}
  lang={lang}
  currentPath="/"
  minimal
>
  <section class="min-h-screen bg-surface px-5 py-8 sm:px-8 lg:px-12">
    <nav
      class="mb-8 flex justify-end gap-2 text-xs font-semibold uppercase tracking-wide"
      aria-label="Language"
    >
      <a
        href={DOMAINS.en}
        class:list={[
          'transition-colors',
          lang === 'en' ? 'text-heading' : 'text-body hover:text-primary',
        ]}
        aria-current={lang === 'en' ? 'page' : undefined}
      >
        EN
      </a>
      <span class="text-border" aria-hidden="true">/</span>
      <a
        href={DOMAINS.sk}
        class:list={[
          'transition-colors',
          lang === 'sk' ? 'text-heading' : 'text-body hover:text-primary',
        ]}
        aria-current={lang === 'sk' ? 'page' : undefined}
      >
        SK
      </a>
    </nav>

    <div class="mx-auto grid min-h-[calc(100vh-8rem)] max-w-6xl grid-cols-1 items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <div class="mx-auto w-full max-w-[540px] lg:mx-0">
        <img
          src="/images/matej-lukasik-profile.jpg"
          alt="Matej Lukášik"
          width="1600"
          height="2400"
          class="block max-h-[78vh] w-full rounded-lg object-contain"
        />
      </div>

      <div class="max-w-xl">
        <h1 class="text-4xl font-bold text-heading sm:text-5xl">{profile.greeting}</h1>
        <div class="mt-6 space-y-5 text-lg leading-relaxed text-body">
          {profile.paragraphs.map((paragraph) => (
            <p>
              {'text' in paragraph ? (
                paragraph.text
              ) : (
                <>{paragraph.before}<a
                    href={paragraph.href}
                    class="text-primary transition-colors hover:text-primary-hover"
                    target="_blank"
                    rel="noopener noreferrer"
                  >{paragraph.linkText}</a>{paragraph.after}</>
              )}
            </p>
          ))}
        </div>

        <nav class="mt-8 flex flex-wrap gap-x-5 gap-y-3 text-base font-medium" aria-label="Contact and profiles">
          {links.map((link) => (
            <a
              href={link.href}
              class="text-primary transition-colors hover:text-primary-hover"
              target={link.href.startsWith('http') ? '_blank' : undefined}
              rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    </div>
  </section>
</Layout>
