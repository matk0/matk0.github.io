---
interface Step {
  label: string;
  title: string;
  description: string;
}

interface Props {
  title: string;
  steps: Step[];
}

const { title, steps } = Astro.props;
---

<section class="section-padding bg-surface relative" data-analytics-section="process">
  <div class="container mx-auto">
    <h2 class="text-2xl md:text-4xl font-bold text-center mb-16 reveal">
      <span class="gradient-text-dark">{title}</span>
    </h2>
    <div class="relative max-w-4xl mx-auto">
      <div class="hidden md:block absolute left-8 top-0 bottom-0 w-px bg-gradient-to-b from-primary/30 via-primary/15 to-transparent"></div>
      <div class="space-y-12 md:space-y-16">
        {steps.map((step, i) => (
          <div class:list={["relative flex gap-6 md:gap-10 items-start reveal", `reveal-delay-${i + 1}`]}>
            <div class="shrink-0 w-16 h-16 rounded-2xl bg-primary-light flex items-center justify-center relative z-10">
              <span class="text-primary font-bold text-lg" style="font-family: var(--font-heading);">{step.label}</span>
            </div>
            <div class="pt-2">
              <h3 class="text-lg md:text-xl font-bold text-heading mb-2">{step.title}</h3>
              <p class="text-body text-sm md:text-base leading-relaxed max-w-lg">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
