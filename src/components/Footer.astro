---
import { t, getLocalizedPaths, ATLAS_URL } from '../i18n';
import type { Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const strings = t(lang);
const paths = getLocalizedPaths(lang);
const year = new Date().getFullYear();
---

<footer class="bg-primary-dark text-white/70">
  <div class="container mx-auto px-4 sm:px-6 section-padding !pb-8">
    <div class="grid grid-cols-1 md:grid-cols-[1.25fr_0.75fr_0.9fr_0.9fr_0.75fr] gap-10 lg:gap-12 mb-12">
      <div>
        <a href="/" class="inline-flex items-center" aria-label="Matej Lukášik">
          <img src="/logo.svg" alt="Matej Lukášik" width="48" height="48" class="block h-12 w-12" />
        </a>
        <p class="mt-4 text-sm leading-relaxed max-w-xs">{strings.footer.description}</p>
      </div>

      <div>
        <p class="text-sm font-semibold text-white uppercase tracking-wider mb-4">{strings.footer.navigation}</p>
        <ul class="space-y-2">
          <li><a href="/#services" class="text-sm hover:text-white transition-colors">{strings.nav.services}</a></li>
          <li><a href="/#about" class="text-sm hover:text-white transition-colors">{strings.nav.about}</a></li>
          <li><a href={paths.contact} class="text-sm hover:text-white transition-colors">{strings.nav.contact}</a></li>
          <li><a href="/#faq" class="text-sm hover:text-white transition-colors">{strings.nav.faq}</a></li>
        </ul>
      </div>

      <div>
        <p class="text-sm font-semibold text-white uppercase tracking-wider mb-4">{strings.footer.getInTouch}</p>
        <ul class="space-y-3">
          <li>
            <a
              href={`mailto:${strings.contact.email}`}
              class="text-sm hover:text-white transition-colors"
              data-analytics-event="mailto_clicked"
              data-analytics-position="footer"
            >
              {strings.contact.email}
            </a>
          </li>
        </ul>
      </div>

      <div>
        <p class="text-sm font-semibold text-white uppercase tracking-wider mb-4">{strings.footer.research}</p>
        <ul class="space-y-2">
          <li>
            <a
              href={ATLAS_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm hover:text-white transition-colors"
              data-analytics-event="external_link_clicked"
              data-analytics-destination="agent_threat_atlas"
              data-analytics-position="footer"
            >
              {strings.footer.agentThreatAtlas}
            </a>
          </li>
        </ul>
      </div>

      <div>
        <p class="text-sm font-semibold text-white uppercase tracking-wider mb-4">{strings.footer.followMe}</p>
        <div class="flex gap-4">
          <a href="https://www.linkedin.com/in/matej-lukasik" target="_blank" rel="noopener noreferrer" class="text-white/70 hover:text-white transition-colors" aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://x.com/matejlukasik" target="_blank" rel="noopener noreferrer" class="text-white/70 hover:text-white transition-colors" aria-label="X">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://youtube.com/@matejlukasik" target="_blank" rel="noopener noreferrer" class="text-white/70 hover:text-white transition-colors" aria-label="YouTube">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <div class="border-t border-white/10 pt-8 flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between">
      <p class="text-sm text-white/60">&copy; {year} {strings.footer.copyright}</p>
      <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:gap-4">
        <a href={paths.privacy} class="text-sm text-white/60 hover:text-white transition-colors">{strings.footer.privacy}</a>
        <button
          type="button"
          class="text-left text-sm text-white/60 transition-colors hover:text-white sm:text-right"
          data-cookie-settings
        >
          {strings.footer.cookieSettings}
        </button>
      </div>
    </div>
  </div>
</footer>
