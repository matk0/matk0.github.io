---
import type { Lang } from '../i18n';
import { getLocalizedPaths, t } from '../i18n';

interface Props {
  title: string;
  description: string;
  lang: Lang;
}

const { title, description, lang } = Astro.props;
const strings = t(lang);
const paths = getLocalizedPaths(lang);
---

<div id="booking-calendar" class="rounded-2xl p-4 -m-4">
  <h3 class="text-xl font-bold text-heading mb-2">{title}</h3>
  <p class="text-body text-sm mb-6">{description}</p>
  <p class="text-xs leading-relaxed text-body/80 mb-6">
    {strings.contact.bookingPrivacyNotice}
    {' '}
    <a href={paths.privacy} class="font-medium text-primary hover:text-primary-hover">{strings.contact.privacyLink}</a>
  </p>
  <div class="rounded-xl border border-border overflow-hidden bg-surface-alt min-h-[400px]">
    <div id="cal-embed" class="w-full"></div>
  </div>
</div>

<script is:inline>
  const bookingCalendar = document.getElementById('booking-calendar');
  const shouldFlashCalendar = new URLSearchParams(window.location.search).get('focus') === 'calendar';

  if (bookingCalendar && shouldFlashCalendar) {
    requestAnimationFrame(() => {
      bookingCalendar.classList.add('booking-calendar-flash');
    });
  }
</script>

<script is:inline>
  (function (C, A, L) {
    let p = function (a, ar) { a.q.push(ar); };
    let d = C.document;
    C.Cal = C.Cal || function () { var ar = arguments; let cal = C.Cal; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; if (typeof namespace === "string") { cal.ns[namespace] = cal.ns[namespace] || api; p(cal.ns[namespace], ar); p(cal, ["initNamespace", namespace]); } else p(cal, ar); return; } p(cal, ar); };
  })(window, "https://app.cal.com/embed/embed.js", "init");
  Cal("init", { origin: "https://cal.com" });
  Cal("inline", {
    elementOrSelector: "#cal-embed",
    calLink: "matejlukasik/30min",
    config: { layout: "month_view" },
  });
  Cal("ui", { hideEventTypeDetails: false, layout: "month_view" });
  const trackCalendarEvent = (eventName, props = {}) => {
    window.trackSiteEvent?.(eventName, {
      source: new URLSearchParams(window.location.search).get('focus') === 'calendar' ? 'booking_cta' : 'contact_page',
      ...props,
    });
  };

  Cal("on", {
    action: "bookerViewed",
    callback: (event) => {
      const details = event.detail?.data || {};

      trackCalendarEvent('cal_booker_viewed', {
        eventSlug: details.eventSlug || 'unknown',
        slotsLoaded: details.slotsLoaded,
      });
    },
  });

  Cal("on", {
    action: "bookerReady",
    callback: (event) => {
      const details = event.detail?.data || {};

      trackCalendarEvent('cal_booker_ready', {
        eventSlug: details.eventSlug || 'unknown',
      });
    },
  });

  Cal("on", {
    action: "bookingSuccessfulV2",
    callback: (event) => {
      const details = event.detail?.data || {};

      trackCalendarEvent('booking_successful', {
        status: details.status || 'unknown',
        paymentRequired: details.paymentRequired,
        isRecurring: details.isRecurring,
      });
    },
  });
</script>
