---
interface FAQItem {
  question: string;
  answer: string;
  linkText?: string;
  linkHref?: string;
}

interface Props {
  title: string;
  items: FAQItem[];
}

const { title, items } = Astro.props;
---

<section id="faq" class="section-padding bg-surface-alt" data-analytics-section="faq">
  <div class="container mx-auto max-w-3xl">
    <h2 class="text-2xl md:text-3xl font-bold text-heading text-center mb-10">{title}</h2>
    <div class="space-y-4">
      {items.map((item, index) => (
        <details
          class="group bg-surface border border-border rounded-xl"
          data-analytics-event="faq_opened"
          data-analytics-index={index + 1}
        >
          <summary class="flex items-center justify-between cursor-pointer px-6 py-5 text-heading font-semibold text-sm md:text-base">
            {item.question}
            <svg class="w-5 h-5 text-body shrink-0 ml-4 transition-transform group-open:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
          </summary>
          <div class="px-6 pb-5 text-body text-sm leading-relaxed">
            <p>{item.answer}</p>
            {item.linkHref && item.linkText && (
              <a href={item.linkHref} target="_blank" rel="noopener noreferrer" class="mt-3 inline-flex items-center font-semibold text-primary hover:text-primary-hover transition-colors">
                {item.linkText}
                <span aria-hidden="true" class="ml-1">→</span>
              </a>
            )}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
