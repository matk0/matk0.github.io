---
interface Props {
  id: string;
  eyebrow: string;
  title: string;
  description: string;
  ctaText: string;
  ctaHref: string;
}

const { id, eyebrow, title, description, ctaText, ctaHref } = Astro.props;
---

<section id={id} class="section-padding bg-surface relative scroll-mt-24" data-analytics-section="atlas_landing">
  <div class="container mx-auto">
    <div class="grid gap-6 border-y border-border py-10 md:grid-cols-[1fr_auto] md:items-center">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-wider text-primary mb-3">{eyebrow}</p>
        <h2 class="text-2xl md:text-3xl font-bold text-heading mb-4">{title}</h2>
        <p class="text-body text-base md:text-lg leading-relaxed">{description}</p>
      </div>
      <a
        href={ctaHref}
        class="btn-primary whitespace-nowrap"
        data-analytics-event="service_cta_clicked"
        data-analytics-service="agentic_ai_security"
        data-analytics-position="atlas_landing"
        data-analytics-target="contact_form"
      >
        {ctaText}
      </a>
    </div>
  </div>
</section>
