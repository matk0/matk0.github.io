---
interface Props {
  id: string;
  title: string;
  subtitle: string;
  description: string;
  includes: string[];
  ctaText: string;
  ctaHref: string;
  ctaTarget?: 'calendar' | 'contact_form';
  imageSrc: string;
  imageAlt?: string;
  reversed?: boolean;
  bg?: 'white' | 'alt';
  nested?: boolean;
}

const { id, title, subtitle, description, includes, ctaText, ctaHref, ctaTarget = 'contact_form', imageSrc, imageAlt = '', reversed = false, bg = 'white', nested = false } = Astro.props;
---

<section
  id={id}
  class:list={[
    "relative",
    nested ? "rounded-2xl bg-surface border border-border/60 shadow-sm p-6 md:p-10 lg:p-12" : "section-padding",
    !nested && (bg === 'alt' ? "bg-surface-alt" : "bg-surface bg-dots"),
  ]}
  data-analytics-section={id}
>
  <div class:list={["grid grid-cols-1 lg:grid-cols-2 gap-12 items-center", !nested && "container mx-auto"]}>
    <div class:list={["reveal", reversed && "lg:order-2"]}>
      <h2 class="text-2xl md:text-3xl font-bold text-heading mb-3">{title}</h2>
      <p class="text-lg text-primary font-medium mb-4">{subtitle}</p>
      <p class="text-body leading-relaxed mb-6">{description}</p>
      <ul class="space-y-3 mb-8">
        {includes.map((item) => (
          <li class="flex items-start gap-3 text-body text-sm">
            <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            {item}
          </li>
        ))}
      </ul>
      <a
        href={ctaHref}
        class="btn-primary"
        data-analytics-event="service_cta_clicked"
        data-analytics-service={id}
        data-analytics-position="service_section"
        data-analytics-target={ctaTarget}
      >
        {ctaText}
      </a>
    </div>
    <div class:list={["reveal reveal-delay-2", reversed && "lg:order-1"]}>
      <div class="rounded-2xl bg-gradient-to-br from-primary-light to-surface-alt p-4 md:p-6 flex items-center justify-center min-h-[300px] relative overflow-hidden group border border-border/60 shadow-sm">
        <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-accent/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <img src={imageSrc} alt={imageAlt} class="relative z-10 w-full rounded-xl object-cover aspect-[4/3] group-hover:scale-[1.02] transition-transform duration-500" loading="lazy" />
      </div>
    </div>
  </div>
</section>
