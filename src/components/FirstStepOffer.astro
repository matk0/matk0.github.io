---
interface Offer {
  eyebrow: string;
  title: string;
  description: string;
  cta: string;
}

interface Props {
  offer: Offer;
  href: string;
}

const { offer, href } = Astro.props;
---

<section class="section-padding bg-surface-alt relative" data-analytics-section="first_step_offer">
  <div class="container mx-auto">
    <div class="max-w-3xl mx-auto text-center reveal">
      <p class="text-sm font-semibold uppercase tracking-wider text-primary mb-3">{offer.eyebrow}</p>
      <h2 class="text-2xl md:text-4xl font-bold text-heading mb-5">{offer.title}</h2>
      <p class="text-body text-base md:text-lg leading-relaxed max-w-2xl mx-auto mb-8">{offer.description}</p>
      <a
        href={href}
        class="btn-primary"
        data-analytics-event="booking_intent_clicked"
        data-analytics-position="first_step_offer"
        data-analytics-target="calendar"
      >
        {offer.cta}
      </a>
    </div>
  </div>
</section>
