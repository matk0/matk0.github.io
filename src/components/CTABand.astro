---
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<section class="relative overflow-hidden cta-band" data-analytics-section="final_cta">
  <div class="cta-gradient"></div>
  <div class="absolute inset-0 bg-gradient-to-br from-primary/30 to-transparent"></div>
  <div class="container mx-auto px-4 sm:px-6 py-20 md:py-24 relative z-10 text-center">
    <h2 class="text-2xl md:text-4xl font-bold text-white mb-4 reveal">{title}</h2>
    {description && (
      <p class="text-white/80 text-lg max-w-xl mx-auto mb-8 reveal reveal-delay-1">{description}</p>
    )}
    <div class="flex flex-col sm:flex-row gap-4 justify-center reveal reveal-delay-2">
      <slot />
    </div>
  </div>
</section>

<style>
  .cta-band {
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent), var(--color-primary));
    background-size: 400% 400%;
    animation: aurora 10s ease infinite;
  }

  .cta-gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 50% 80% at 20% 50%, rgba(255,255,255,0.05), transparent),
      radial-gradient(ellipse 50% 80% at 80% 50%, rgba(255,255,255,0.08), transparent);
  }
</style>
