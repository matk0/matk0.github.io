---
interface Props {
  title: string;
  description: string;
  icon: string;
  href: string;
  linkText: string;
}

const { title, description, icon, href, linkText } = Astro.props;
---

<div class="tilt-card bg-surface rounded-2xl p-8 border border-border hover:border-primary/20 transition-all duration-300 group relative overflow-hidden" data-tilt>
  <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-primary/5 to-transparent rounded-bl-full opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
  <div class="relative z-10">
    <div class="w-12 h-12 rounded-xl bg-primary-light flex items-center justify-center text-2xl mb-5 group-hover:scale-110 transition-transform duration-300">
      {icon}
    </div>
    <h3 class="text-xl font-bold text-heading mb-3">{title}</h3>
    <p class="text-body text-sm leading-relaxed mb-5">{description}</p>
    <a href={href} class="inline-flex items-center text-sm font-semibold text-primary hover:text-primary-hover transition-colors gap-1">
      {linkText}
      <svg class="w-4 h-4 group-hover:translate-x-1.5 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</div>
