---
interface Props {
  title: string;
  description: string;
  imageSrc: string;
  imageAlt?: string;
  href: string;
  linkText: string;
}

const { title, description, imageSrc, imageAlt = '', href, linkText } = Astro.props;
---

<div class="tilt-card h-full flex flex-col bg-surface rounded-2xl p-6 border border-border hover:border-primary/20 transition-all duration-300 group relative overflow-hidden" data-tilt>
  <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-primary/5 to-transparent rounded-bl-full opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
  <div class="relative z-10 h-full flex flex-col">
    <div class="w-full aspect-[4/3] rounded-2xl bg-primary-light overflow-hidden mb-6 shadow-sm border border-border/60 group-hover:shadow-lg group-hover:shadow-primary/10 transition-all duration-300">
      <img src={imageSrc} alt={imageAlt} class="w-full h-full object-cover" loading="lazy" />
    </div>
    <h3 class="text-xl font-bold text-heading mb-3">{title}</h3>
    <p class="text-body text-sm leading-relaxed mb-5">{description}</p>
    <a href={href} class="mt-auto inline-flex items-center text-sm font-semibold text-primary hover:text-primary-hover transition-colors gap-1">
      {linkText}
      <svg class="w-4 h-4 group-hover:translate-x-1.5 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</div>
