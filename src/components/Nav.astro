---
import { t, getAlternateUrl, getAlternateLang, getLocalizedPaths } from '../i18n';
import type { Lang } from '../i18n';

interface Props {
  lang: Lang;
  currentPath: string;
  currentUrl?: URL;
}

const { lang, currentPath, currentUrl } = Astro.props;
const strings = t(lang);
const altLang = getAlternateLang(lang);
const altUrl = getAlternateUrl(lang, currentPath, currentUrl);
const paths = getLocalizedPaths(lang);
const bookingHref = `${paths.contact}?focus=calendar`;
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-surface/85 backdrop-blur-xl saturate-150 border-b border-border/50 shadow-sm shadow-black/[0.03]">
  <div class="container mx-auto px-4 sm:px-6 h-16 flex items-center justify-between md:grid md:grid-cols-[1fr_auto_1fr] md:justify-normal">
    <a href="/" class="inline-flex items-center rounded-xl md:justify-self-start" aria-label="Matej Lukášik">
      <img src="/logo.svg" alt="Matej Lukášik" width="40" height="40" class="block h-10 w-10" />
    </a>

    <div class="hidden md:flex items-center gap-1 md:justify-self-center">
      <a href="/#services" class="nav-pill">
        {strings.nav.services}
      </a>
      <a href="/#about" class="nav-pill">
        {strings.nav.about}
      </a>
      <a href="/#faq" class="nav-pill">
        {strings.nav.faq}
      </a>
      <a href={paths.contact} class:list={["nav-pill", currentPath === paths.contact && "nav-pill-active"]}>
        {strings.nav.contact}
      </a>
    </div>

    <div class="flex items-center gap-3 md:justify-self-end">
      <a
        href={altUrl}
        class="text-sm font-medium text-body hover:text-primary transition-colors px-2 py-1 rounded-lg hover:bg-primary-light"
      >
        {altLang.toUpperCase()}
      </a>
      <a
        href={bookingHref}
        class="hidden sm:inline-flex btn-primary !py-2 !px-4 !text-sm"
        data-analytics-event="booking_intent_clicked"
        data-analytics-position="nav_desktop"
        data-analytics-target="calendar"
      >
        {strings.nav.bookCall}
      </a>

      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-body hover:text-heading"
        aria-label="Menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-border bg-surface" aria-hidden="true">
    <div class="container mx-auto px-4 py-4 flex flex-col gap-3">
      <a href="/#services" class="text-sm font-medium text-body hover:text-primary py-2">{strings.nav.services}</a>
      <a href="/#about" class="text-sm font-medium text-body hover:text-primary py-2">{strings.nav.about}</a>
      <a href="/#faq" class="text-sm font-medium text-body hover:text-primary py-2">{strings.nav.faq}</a>
      <a href={paths.contact} class="text-sm font-medium text-body hover:text-primary py-2">{strings.nav.contact}</a>
      <a
        href={bookingHref}
        class="btn-primary !text-sm mt-2"
        data-analytics-event="booking_intent_clicked"
        data-analytics-position="nav_mobile"
        data-analytics-target="calendar"
      >
        {strings.nav.bookCall}
      </a>
    </div>
  </div>
</nav>

<div class="h-16"></div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  const setMenuOpen = (open) => {
    menu?.classList.toggle('hidden', !open);
    menu?.setAttribute('aria-hidden', String(!open));
    btn?.setAttribute('aria-expanded', String(open));
  };

  btn?.addEventListener('click', () => {
    setMenuOpen(btn.getAttribute('aria-expanded') !== 'true');
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => setMenuOpen(false));
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && btn?.getAttribute('aria-expanded') === 'true') {
      setMenuOpen(false);
      btn?.focus();
    }
  });
</script>
